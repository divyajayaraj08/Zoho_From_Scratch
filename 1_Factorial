// Factorial of a number
import java.util.Scanner;
class Factorial{
	public static void main(String args[]){
		System.out.println("Enter number : " );
		Scanner scan = new Scanner(System.in);
		int n= scan.nextInt();
		int fact=1;
		for(int i=n;i>=1;i--){
		 fact= fact*i;
		}
		System.out.println("Factorial of" + n+ " is "+fact);
}
}
