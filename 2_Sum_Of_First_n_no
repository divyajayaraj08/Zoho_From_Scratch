import java.util.Scanner;

class Sum {
    public static void main(String args[]) {
        System.out.println("Enter n: ");
        Scanner scan = new Scanner(System.in);
        int n = scan.nextInt();
        int sum = 0;

        for (int i = 1; i <= n; i++) {
            sum = sum + i;
        }

        System.out.println("The sum is " + sum);
        scan.close();
    }
}
