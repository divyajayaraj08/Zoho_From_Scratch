// Count no of digits in number
import java.util.Scanner;
class Count{
	public static void main(String args[]){
		System.out.println("Enter number : ");
		Scanner scan = new Scanner(System.in);
		int n = scan.nextInt();
		int count =0;
		if (n==0){
		System.out.println(1);
	}
		while (n!=0){
			n=n/10;
			count ++;
		}
		System.out.println(count);
}
}
