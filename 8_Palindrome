// Palindrome
 
import java.util.Scanner;
class Palindrome{
	public static void main (String args[]){
		System.out.println("Enter number : ");
		Scanner scan = new Scanner(System.in);
		int n=scan.nextInt();
		int temp=n;
		int rev=0;
		while (n>0){
			int dig= n%10;
			rev = rev *10+ dig;
			n=n/10;
		}
		if(rev==temp){
			System.out.println("Palindrome");
		}
		else{
			System.out.println("Not a palindrome");
		}
		
}
}
